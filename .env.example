# ================================
# Mandure Serviços — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ================================

# --- Empresa ---
NEXT_PUBLIC_COMPANY_NAME="Mandure Serviços"
NEXT_PUBLIC_COMPANY_TAGLINE="Construindo com solidez e precisão há mais de 15 anos"

# --- Contato ---
NEXT_PUBLIC_WHATSAPP_NUMBER="5511999999999"
NEXT_PUBLIC_WHATSAPP_MESSAGE="Olá! Gostaria de solicitar um orçamento para meu projeto. Poderia me ajudar?"
NEXT_PUBLIC_EMAIL="contato@mandureservicos.com.br"
NEXT_PUBLIC_PHONE="(11) 9 9999-9999"

# --- Endereço ---
NEXT_PUBLIC_ADDRESS="Av. Paulista, 1000, Sala 101"
NEXT_PUBLIC_CITY="São Paulo"
NEXT_PUBLIC_STATE="SP"

# --- Redes Sociais ---
NEXT_PUBLIC_INSTAGRAM="https://instagram.com/mandureservicos"
NEXT_PUBLIC_FACEBOOK="https://facebook.com/mandureservicos"

# --- Site ---
NEXT_PUBLIC_SITE_URL="https://mandureservicos.com.br"

# --- Analytics (opcional) ---
NEXT_PUBLIC_GA_ID=

# --- Sentry (monitoramento de erros/performance) ---
# DSN publico (client-side). Exemplo: https://<key>@o0.ingest.sentry.io/<project-id>
NEXT_PUBLIC_SENTRY_DSN=

# DSN privado opcional para server/edge (se vazio, usa NEXT_PUBLIC_SENTRY_DSN)
SENTRY_DSN=
# Ambiente logico no Sentry (development, test, production)
SENTRY_ENVIRONMENT=development
# Taxa de captura de traces (0 a 1)
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Sobrescreve no server/edge; se vazio, usa NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE
SENTRY_TRACES_SAMPLE_RATE=

# --- Sentry Build Plugin (upload de sourcemaps no CI/CD) ---
SENTRY_ORG=gabriel-db
SENTRY_PROJECT=mandure-servicos
# Token secreto do Sentry (NUNCA usar NEXT_PUBLIC_)
SENTRY_AUTH_TOKEN=
